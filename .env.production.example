# Copy to .env on the server if you use Docker Compose for MySQL/Redis/Elasticsearch.
# Keep the real .env out of git.

# MySQL demo database. Bound to 127.0.0.1 by docker-compose.yml.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=refund_agent
MYSQL_USER=refund_user
MYSQL_PASSWORD=change-me-refund-password

# Elasticsearch memory budget. 512m is suitable for a small 4GB demo VM.
ES_JAVA_OPTS=-Xms512m -Xmx512m
