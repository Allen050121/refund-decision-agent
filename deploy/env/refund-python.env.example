# Copy to /opt/refund-decision-agent/env/refund-python.env on the server.
# Do not commit the real file.

APP_HOST=0.0.0.0
APP_PORT=8001
JAVA_API_URL=http://127.0.0.1:8080
JAVA_API_TOKEN=internal-service-token
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_STREAM_NAME=after-sale:agent:tasks
ELASTICSEARCH_URL=http://127.0.0.1:9201
ELASTICSEARCH_INDEX=refund-rules

LLM_BASE_URL=https://example.com/v1
LLM_MODEL=your-model-name
OPENAI_API_KEY=replace-with-real-key-on-server
LLM_PROXY_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

MAX_TASK_TIMEOUT=300
MAX_MODEL_CALLS=10
MAX_TOOL_CALLS=15
MAX_TOKEN_COST=1.0
