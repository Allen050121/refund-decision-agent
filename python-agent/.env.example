# Python Agent Environment Variables Template
# Copy this file to .env and update with your actual values

# Service Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Java API (本地运行)
JAVA_API_URL=http://localhost:8080
JAVA_API_TOKEN=change-me-to-secure-token

# Redis (配置为你的 Redis 地址)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_NAME=after-sale:agent:tasks

# Elasticsearch (配置为你的 ES 地址)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=refund-rules

# LLM (Use your preferred provider)
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# Freemodel/OpenAI-compatible gateway: set the gateway /v1 endpoint here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
# Optional. Leave empty unless your network requires a local HTTP proxy.
LLM_PROXY_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
OPENAI_API_KEY=your-api-key-here

# Embedding
EMBEDDING_MODEL=text-embedding-ada-002

# Langfuse Observability (Optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Task Limits
MAX_TASK_TIMEOUT=300
MAX_MODEL_CALLS=10
MAX_TOOL_CALLS=15
MAX_TOKEN_COST=1.0
